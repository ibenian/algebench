{
  "name": "minimal-flat-light",
  "mode": "light",
  "direction": "LR",
  "labelMode": "emoji",
  "nodeStyles": {
    "scalar":   { "shape": "rect", "fill": "none", "stroke": "none", "color": "#999" },
    "vector":   { "shape": "rect", "fill": "none", "stroke": "none", "color": "#999" },
    "constant": { "shape": "rect", "fill": "none", "stroke": "none", "color": "#999" },
    "number":     { "shape": "rect", "fill": "none", "stroke": "none", "color": "#999" },
    "expression": { "shape": "rect", "fill": "none", "stroke": "none", "color": "#999" },
    "text":       { "shape": "rect", "fill": "none", "stroke": "none", "color": "#999" },
    "operator":   { "shape": "rect", "fill": "none", "stroke": "none", "color": "#999" },
    "function": { "shape": "rect", "fill": "none", "stroke": "none", "color": "#999" },
    "relation": { "shape": "rect", "fill": "none", "stroke": "none", "color": "#999" },
    "result":   { "shape": "rect", "fill": "none", "stroke": "none", "color": "#999" },
    "annotation": { "shape": "circle",  "fill": "#f3f3f6", "stroke": "#aaa", "color": "#666" }
  },
  "edgeStyles": {
    "direct":  { "stroke": "#b04040", "strokeWidth": 1.5 },
    "inverse": { "stroke": "#4070a0", "strokeWidth": 1, "arrow": "-.->" },
    "neutral": { "stroke": "#999",    "strokeWidth": 1 }
  },
  "paintBySemantic": true,
  "fontSize": 16
}
