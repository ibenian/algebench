{
  "name": "textbook-dark",
  "mode": "dark",
  "direction": "TB",
  "labelMode": "emoji",
  "nodeStyles": {
    "scalar":     { "shape": "circle", "fill": "none",    "stroke": "none",    "color": "#b0b0b0" },
    "vector":     { "shape": "circle", "fill": "#1e2228", "stroke": "#607090", "color": "#a0b8d0" },
    "constant":   { "shape": "circle", "fill": "none",    "stroke": "none",    "color": "#b0b0b0" },
    "number":     { "shape": "circle", "fill": "none",    "stroke": "none",    "color": "#b0b0b0" },
    "expression": { "shape": "circle", "fill": "#222228", "stroke": "#707088", "color": "#b0b0c8" },
    "text":       { "shape": "circle", "fill": "#202020", "stroke": "#606060", "color": "#a0a0a0" },
    "ket":        { "shape": "circle", "fill": "#1e2820", "stroke": "#508060", "color": "#90c8a0" },
    "bra":        { "shape": "circle", "fill": "#1e2820", "stroke": "#508060", "color": "#90c8a0" },
    "braket":     { "shape": "circle", "fill": "#202820", "stroke": "#609070", "color": "#a0d8b0" },
    "operator":   { "shape": "rect",  "fill": "#282020", "stroke": "#906050", "color": "#d0a090" },
    "function":   { "shape": "stadium",  "fill": "#282420", "stroke": "#907050", "color": "#d0b090" },
    "relation":   { "shape": "rect",  "fill": "#1e2230", "stroke": "#506898", "color": "#a0b8d8" },
    "result":     { "shape": "rect",  "fill": "#28281e", "stroke": "#909050", "color": "#d0d090" },
    "annotation": { "shape": "circle", "fill": "#1a1a1a", "stroke": "#484848", "color": "#787878" }
  },
  "edgeStyles": {
    "direct":  { "stroke": "#906060", "strokeWidth": 3 },
    "inverse": { "stroke": "#606890", "strokeWidth": 1, "arrow": "-.->" },
    "neutral": { "stroke": "#606060", "strokeWidth": 2 }
  },
  "paintBySemantic": true,
  "fontSize": 15
}
