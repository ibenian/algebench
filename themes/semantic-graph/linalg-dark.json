{
  "name": "linalg-dark",
  "mode": "dark",
  "direction": "TB",
  "labelMode": "emoji",
  "nodeStyles": {
    "scalar":     { "shape": "circle",  "fill": "#2a2010", "stroke": "#d4a050", "color": "#f0d090" },
    "vector":     { "shape": "rect",    "fill": "#1a2a1a", "stroke": "#66bb6a", "color": "#a5d6a7", "strokeWidth": 2 },
    "matrix":     { "shape": "rect",    "fill": "#1a1a2a", "stroke": "#5c6bc0", "color": "#9fa8da", "strokeWidth": 2 },
    "number":     { "shape": "circle",  "fill": "#2a2010", "stroke": "#d4a050", "color": "#f0d090" },
    "expression": { "shape": "circle",  "fill": "#2a2010", "stroke": "#d4a050", "color": "#f0d090" },
    "text":       { "shape": "circle",  "fill": "#2a2010", "stroke": "#d4a050", "color": "#f0d090" },
    "constant":   { "shape": "circle",  "fill": "#2a2010", "stroke": "#d4a050", "color": "#f0d090" },
    "relation":   { "shape": "diamond", "fill": "#2a1020", "stroke": "#c06090", "color": "#f0b0d0" },
    "result":     { "shape": "stadium", "fill": "#102a2a", "stroke": "#26a69a", "color": "#b2dfdb" },
    "annotation": { "shape": "circle",  "fill": "#1a1a28", "stroke": "#505060", "color": "#aaa" }
  },
  "edgeStyles": {
    "direct":  { "stroke": "#ef5350", "strokeWidth": 3 },
    "inverse": { "stroke": "#42a5f5", "strokeWidth": 1, "arrow": "-.->" },
    "neutral": { "stroke": "#777",    "strokeWidth": 2 },
    "logical": { "stroke": "#bdbdbd", "strokeWidth": 2, "arrow": "-.->" }
  },
  "paintBySemantic": true,
  "fontSize": 15
}
