    "matrix":   { "shape": "rect",   "fill": "#1a1a2a", "stroke": "#5c6bc0", "color": "#9fa8da", "strokeWidth": 2 },
    "number":   { "shape": "rect",   "fill": "none",    "stroke": "none",    "color": "#ccc" },
    "constant": { "shape": "rect",   "fill": "none",    "stroke": "none",    "color": "#ccc" },
    "operator": { "shape": "circle", "fill": "#2a2a3a", "stroke": "#555",    "color": "#ccc" },
    "function": { "shape": "circle", "fill": "#2a2a3a", "stroke": "#555",    "color": "#ccc" },
