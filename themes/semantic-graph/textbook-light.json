{
  "name": "textbook-light",
  "mode": "light",
  "direction": "TB",
  "labelMode": "emoji",
  "nodeStyles": {
    "scalar":   { "shape": "circle",   "fill": "#fdf5e6", "stroke": "#a0784c", "color": "#5c3a1e" },
    "vector":   { "shape": "circle",   "fill": "#fdf5e6", "stroke": "#a0784c", "color": "#5c3a1e" },
    "constant": { "shape": "circle",   "fill": "#fdf5e6", "stroke": "#a0784c", "color": "#5c3a1e" },
    "number":   { "shape": "circle",   "fill": "#fdf5e6", "stroke": "#a0784c", "color": "#5c3a1e" },
    "relation": { "shape": "diamond",  "fill": "#e8eaf6", "stroke": "#3949ab", "color": "#1a237e" },
    "result":   { "shape": "stadium",  "fill": "#fbe9e7", "stroke": "#bf360c", "color": "#7f2000" },
    "annotation": { "shape": "circle", "fill": "#f5f5f8", "stroke": "#aaa", "color": "#666" }
  },
  "edgeStyles": {
    "direct":  { "stroke": "#b71c1c", "strokeWidth": 3 },
    "inverse": { "stroke": "#3949ab", "strokeWidth": 1, "arrow": "-.->" },
    "neutral": { "stroke": "#999",    "strokeWidth": 2 }
  },
  "paintBySemantic": true,
  "fontSize": 15
}
