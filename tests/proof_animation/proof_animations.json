          "change_type": "rewrite"
        },
        {
          "operation": "Subtract $\\frac{b}{2a}$ from both sides.",
          "expr_latex": "x = - \\frac{b}{2a} + \\frac{\\sqrt{- 4 \\cdot a \\cdot c + b^{2}}}{2 \\cdot a}",
