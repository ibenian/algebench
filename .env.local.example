# Local secrets — copy to .env.local (gitignored) and fill in.
# Loaded by ./algebench at startup; values already in the environment win.

# Gemini API key. Used by:
#   - /api/audio/tts          (gemini-live-tools)
#   - /api/explain            (chat completions)
#   - /api/graph/enrich       (semantic graph enrichment agent — issue #122)
GEMINI_API_KEY=

# Optional model override (defaults to gemini-3-flash-preview for chat,
# gemini-2.0-flash for the enrichment agent).
# GEMINI_MODEL=gemini-2.0-flash

# Per-IP rate limits for the billable (Gemini-backed) endpoints, as
# "count/seconds" (max requests per client IP per window). Protects Gemini
# spend on a public, unauthenticated deployment. Bad values fall back to the
# default shown. Set in the Render dashboard to tune without a code change.
# ALGEBENCH_RATELIMIT_CHAT=20/60     # /api/chat
# ALGEBENCH_RATELIMIT_TTS=20/60      # /api/tts/stream
# ALGEBENCH_RATELIMIT_ENRICH=60/60   # /api/graph/enrich

# /api/tts/stream playback mode. Realtime (default) streams raw PCM from a
# single Live session; set to false for buffered parallel WAV (more robust
# through some hosted proxies). Accepts 1/true/yes/on or 0/false/no/off.
# The CLI launcher sets this explicitly and ignores the env var.
# ALGEBENCH_TTS_REALTIME=true

# --- Proof-completion expert — REFINEMENT-LOOP REWARD (issue #372) ----------
# How the step-by-step derivation expert (behind /api/expert/proof_animation)
# SCORES and RETRIES a derivation. This same blended reward is the offline
# OPTIMIZER metric (optimize.py) and, when enabled, the refinement reward used
# while generating. The judge here (`ProofJudge`) rates PEDAGOGY — clarity,
# step size, rigor — NOT correctness, and is weighted so it can never override
# the CAS grounding (a Refuted step can't be rescued by a perfect judge).
# Defaults shown; all optional.
# Max refinement attempts (1 = single pass, loop disabled):
# ALGEBENCH_PC_REFINE_ATTEMPTS=2
# Enable the pedagogy LLM-as-judge reward term (adds one LM call per generation):
# ALGEBENCH_PC_JUDGE=0
# Wall-clock budget (s) for the refinement loop — don't start a retry past it
# (the UI aborts derivations at 360s). 0 disables the budget:
# ALGEBENCH_PC_TIME_BUDGET=240
# Retry threshold τ — retry while reward < τ:
# ALGEBENCH_PC_TAU=0.7
# Reward weights (grounding is weighted to dominate the pedagogy judge):
# ALGEBENCH_PC_W_GROUNDING=0.8
# ALGEBENCH_PC_W_JUDGE=0.2
# Repo-root-relative path to a compiled artifact to load (confined to the repo;
# absolute / .. paths are rejected). Empty (default) = uncompiled baseline.
# Point it at what optimize.py produced:
# ALGEBENCH_PC_LOAD_ARTIFACT=backend/experts/modules/proof_completion/artifacts/proof_completion.json

# --- Proof-completion expert — INFERENCE-TIME DOMAIN RESCUE (issue #385) -----
# Runs ONLY on the live derive path, AFTER a derivation is built, to grade each
# displayed step's confidence tier. Steps the CAS can't settle — GRAY
# (uncheckable) or BLUE (undecided) — are routed to a domain-expert judge
# (`DomainStepJudge`, fed the domain + lesson context); a step it vouches for is
# rescued into the DOMAIN tier (ranked between Plausible and Verified, labeled
# "valid by domain knowledge, not a symbolic identity"). This is SEPARATE from
# the refinement reward above and never affects training/optimization. The judge
# fires only when an LM is configured. Defaults shown; all optional.
# Master on/off for the whole rescue (ON by default; set 0 to disable the domain
# judge without unconfiguring the LM — confidence stays pure-CAS):
# ALGEBENCH_DOMAIN_RESCUE=1
# Min judge confidence to rescue a GRAY/BLUE step into DOMAIN:
# ALGEBENCH_DOMAIN_MIN_CONF=0.6
# Stricter confidence bar for overriding a RED (refuted) step (only when the RED
# override below is enabled — the CAS actively disagrees, so the bar is high):
# ALGEBENCH_DOMAIN_RED_MIN_CONF=0.9
# Max domain-judge calls per derivation (latency/cost guard; only the
# CAS-undecided steps are ever judged):
# ALGEBENCH_DOMAIN_MAX_CALLS=8
# Allow overriding a RED (refuted) step into DOMAIN — OFF by default (risky:
# the CAS found a concrete contradiction). 1/true/yes to enable:
# ALGEBENCH_DOMAIN_RESCUE_RED=0

# Language model used by the DSPy experts (full litellm model string).
# ALGEBENCH_LM_MODEL=gemini/gemini-2.5-flash
# ALGEBENCH_LM_REASONING=low      # thinking budget: low / minimal / disable
# ALGEBENCH_LM_TEMPERATURE=0      # 0 = deterministic

# --- Logging ---------------------------------------------------------------
# Console level for backend.* loggers. Default WARNING (DEBUG when --debug is
# passed); set INFO/DEBUG to see e.g. proof_completion artifact loading.
# ALGEBENCH_LOG_LEVEL=INFO
