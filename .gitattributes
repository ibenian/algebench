# LOC-REPORT.md is auto-regenerated by .github/workflows/loc-report.yml on
# every push to main, so merge conflicts on it are spurious — the file is
# overwritten on the next push regardless.  ``merge=ours`` tells git to
# keep the current branch's version during merges and rebases.
#
# Requires a one-time per-clone setup:
#
#   git config merge.ours.driver true
#
# (See AGENTS.md → Key Conventions for the setup instruction.)
LOC-REPORT.md merge=ours
